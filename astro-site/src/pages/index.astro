---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
---

<StarlightPage frontmatter={{ title: 'superheld.app', template: 'splash' }}>

  <div class="sh-hero">
    <a href="/" class="sh-hero-badge">
      <span>Dokumentation</span>
      <span>&rarr;</span>
    </a>

    <h1 class="sh-hero-headline">Dein digitaler&nbsp;<br />Schutzschild.</h1>

    <p class="sh-hero-subtitle">
      Plattformübergreifender Schutz für deine digitale Welt.&nbsp;<br />Intuitiv, privat, enterprise-ready.
    </p>

    <div class="sh-hero-buttons">
      <a href="/getting-started/installation" class="sh-hero-btn sh-hero-btn-primary">Jetzt starten</a>
      <a href="/experts/apps" class="sh-hero-btn sh-hero-btn-secondary">Plattformen ansehen</a>
    </div>
  </div>

  <div class="sh-gallery" style="margin-top: 3rem;">
    <div class="sh-gallery-phone">
      <div class="sh-screenshot">
        <img src="/images/screenshot-android.svg" alt="superheld.app auf Android — Dashboard mit Schutzstatus" loading="lazy" />
      </div>
    </div>
    <div class="sh-gallery-desktop">
      <div class="sh-screenshot">
        <img src="/images/screenshot-macos.svg" alt="superheld.app auf macOS — Dashboard mit Geräteübersicht" loading="lazy" />
      </div>
    </div>
    <div class="sh-gallery-phone">
      <div class="sh-screenshot">
        <img src="/images/screenshot-ios.svg" alt="superheld.app auf iOS — Einstellungen" loading="lazy" />
      </div>
    </div>
  </div>

  <div class="sh-section">
    <h2>Features</h2>
    <p class="sh-section-subtitle">Alles was du brauchst, um deine digitale Welt zu schützen — in einer Plattform.</p>
  </div>

  <div class="sh-feature-grid">
    <a href="/getting-started" class="sh-feature-card" style="background: radial-gradient(ellipse at 50% 80%, rgba(37,99,235,0.08), transparent);">
      <div class="sh-feature-card-title">Echtzeit-Schutz</div>
      <p class="sh-feature-card-subtitle">Schützt deine Daten rund um die Uhr mit intelligentem Filtering und sofortiger Bedrohungsabwehr.</p>
    </a>
    <a href="/experts/privacy-security" class="sh-feature-card" style="background: radial-gradient(ellipse at 50% 80%, rgba(16,185,129,0.08), transparent);">
      <div class="sh-feature-card-title">Privatsphäre zuerst</div>
      <p class="sh-feature-card-subtitle">Deine Daten gehören dir. Aller Traffic wird anonymisiert und Ende-zu-Ende verschlüsselt.</p>
    </a>
    <a href="/getting-started/usage" class="sh-feature-card" style="background: radial-gradient(ellipse at 50% 80%, rgba(168,85,247,0.08), transparent);">
      <div class="sh-feature-card-title">Familiensteuerung</div>
      <p class="sh-feature-card-subtitle">Regeln, Zeitlimits und Freigabe-Workflows. Eltern behalten die Kontrolle, Kinder bleiben sicher.</p>
    </a>
    <a href="/experts/apps" class="sh-feature-card" style="background: radial-gradient(ellipse at 50% 80%, rgba(245,158,11,0.08), transparent);">
      <div class="sh-feature-card-title">Plattformübergreifend</div>
      <p class="sh-feature-card-subtitle">Ein Konto, alle Geräte. Nahtlose Synchronisation über iOS, Android, macOS, Windows und Linux.</p>
    </a>
  </div>

  <div class="sh-section">
    <h2>Kindersicherung &amp; Familie</h2>
    <p class="sh-section-subtitle">Volle Kontrolle für Eltern — einfach und übersichtlich.</p>
  </div>

  <div class="sh-gallery">
    <div class="sh-gallery-phone">
      <div class="sh-screenshot">
        <img src="/images/screenshot-kindersicherung.svg" alt="superheld.app Kindersicherung — Profile, Zeitlimits und Freigaben" loading="lazy" />
      </div>
    </div>
    <div class="sh-gallery-desktop">
      <div class="sh-screenshot">
        <img src="/images/screenshot-family-dashboard.svg" alt="superheld.app Familien-Dashboard — Bildschirmzeit und Regeln" loading="lazy" />
      </div>
    </div>
    <div class="sh-gallery-phone">
      <div class="sh-screenshot">
        <img src="/images/screenshot-vpn.svg" alt="superheld.app VPN — Verschlüsselte Verbindung" loading="lazy" />
      </div>
    </div>
  </div>

  <div class="sh-section">
    <h2>Sicherheit &amp; Kontrolle</h2>
    <p class="sh-section-subtitle">Bedrohungen erkennen, Regeln verwalten, Geräte im Blick behalten.</p>
  </div>

  <div class="sh-gallery">
    <div class="sh-gallery-wide">
      <div class="sh-screenshot">
        <img src="/images/screenshot-regeln.svg" alt="superheld.app Filterregeln — Malware, Jugendschutz und Tracker" loading="lazy" />
      </div>
    </div>
    <div class="sh-gallery-wide">
      <div class="sh-screenshot">
        <img src="/images/screenshot-geraete.svg" alt="superheld.app Geräteübersicht — Alle Geräte im Blick" loading="lazy" />
      </div>
    </div>
  </div>

  <div class="sh-section">
    <h2>Dokumentation</h2>
    <p class="sh-section-subtitle">Zwei Wege, ein Ziel — wähle deinen Einstieg.</p>
  </div>

  <div class="sh-feature-grid" data-cols="2">
    <a href="/getting-started" class="sh-feature-card" style="background: radial-gradient(ellipse at 50% 80%, rgba(16,185,129,0.10), transparent); border: 2px solid rgba(16,185,129,0.15);">
      <div class="sh-feature-card-title">Erste Schritte</div>
      <p class="sh-feature-card-subtitle">Installation, Setup und tägliche Nutzung — einfach erklärt, ohne Fachchinesisch.</p>
    </a>
    <a href="/experts" class="sh-feature-card" style="background: radial-gradient(ellipse at 50% 80%, rgba(37,99,235,0.10), transparent); border: 2px solid rgba(37,99,235,0.15);">
      <div class="sh-feature-card-title">Für Experten</div>
      <p class="sh-feature-card-subtitle">Architektur, Sicherheit, Konfiguration und Plattform-Details für fortgeschrittene Nutzer.</p>
    </a>
  </div>

</StarlightPage>
